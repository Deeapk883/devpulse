# Database Settings (Matches docker-compose settings)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=devpulse
DB_PORT=3307

# JWT Settings
JWT_SECRET=your_jwt_secret_key_here

# GitHub OAuth Settings
# Register your app at: https://github.com/settings/developers
# Callback URL should be: http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# GitHub Webhook (Optional)
WEBHOOK_SECRET=your_webhook_secret_here

# Gemini API Settings (Optional - for AI weekly summaries)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
